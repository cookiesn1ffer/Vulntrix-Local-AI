# Vulntrix — environment configuration
# Copy this file to .env and fill in your values.
# Lines starting with # are comments and are ignored.

# ── Auth ──────────────────────────────────────────────────────────────────────
# Set a strong password to protect the web interface.
# Leave empty (or delete this file) for no authentication (local-only use).
BOT_SECRET=igotmanycookies

# How long a login session lasts (hours). Default: 8.
# After this time the user must log in again.
SESSION_TTL_HOURS=8

# ── TLS ───────────────────────────────────────────────────────────────────────
# Generate a self-signed cert: python scripts/gen_cert.py
# The server auto-detects certs/server.key + certs/server.crt and switches to
# HTTPS on port 8443. No config needed here — just run gen_cert.py.

# ── Server ────────────────────────────────────────────────────────────────────
# PORT=8000          # overridden to 8443 automatically when TLS is enabled
MAX_BODY_MB=4        # maximum request body size in megabytes

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=60    # max REST requests per window per IP
RATE_LIMIT_WINDOW=60      # window size in seconds
RATE_LIMIT_WS=10          # max new WebSocket connections per minute per IP

# ── Ollama ────────────────────────────────────────────────────────────────────
# Override if Ollama is running on a different host or port.
VULNTRIX_OLLAMA_URL=http://localhost:11434

# ── Models ────────────────────────────────────────────────────────────────────
# Override the default models used for reasoning and code generation.
# VULNTRIX_REASONING_MODEL=mistral
# VULNTRIX_CODING_MODEL=deepseek-coder

# ── Attacker defaults ─────────────────────────────────────────────────────────
# VULNTRIX_LHOST=10.10.14.1
# VULNTRIX_LPORT=4444
